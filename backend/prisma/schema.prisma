generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-1.1.x", "linux-arm64-openssl-3.0.x"]
}

// Self-contained SQLite persistence. The spec mandates SQLite precisely because no
// external database / PVC is provisioned for this app, so the container must own its
// data file. `DATABASE_URL` defaults to a local file (see Dockerfile + lib/prisma.ts)
// and needs no injected secret. Data is ephemeral across restarts; seed-on-empty keeps
// /tasks populated.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no native enum type; role is stored as a plain string ('ADMIN' | 'USER').
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
}

// Task list domain model. `status` is stored as the string 'todo' | 'done' (display-only
// per spec); no authentication is attached — tasks are a public resource. `createdAt` maps
// to the `created_at` column and is serialized as `created_at` in the JSON API.
model Task {
  id        Int      @id @default(autoincrement())
  title     String
  status    String   @default("todo")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tasks")
}
